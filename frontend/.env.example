# Frontend Environment Variables
# Use /api for both development (proxied by Vite) and production (proxied by nginx)
# This avoids CORS issues as requests stay same-origin
VITE_API_URL=/api

# Comma-separated list of regex patterns for embeddable URL schemas.
# Leave unset or empty to disallow all embeds (default).
# Set to .* to allow all URLs, or e.g. https://.*,http://localhost.* to allow selectively.
# VITE_EMBEDDABLE_SCHEMAS=
